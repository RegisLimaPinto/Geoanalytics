# ── PostgreSQL / PostGIS ─────────────────────────────────────
DATABASE_URL=postgresql://geo:geo@localhost:5432/geoanalytics
POSTGRES_PASSWORD=geo_dev_secret

# ── GeoServer ────────────────────────────────────────────────
GEOSERVER_ADMIN_USER=admin
GEOSERVER_ADMIN_PASSWORD=geoserver_secret

# ── Mapbox (frontend) ────────────────────────────────────────
# Obtenha em: https://account.mapbox.com/access-tokens/
VITE_MAPBOX_TOKEN=YOUR_TOKEN_HERE
